rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Список дозволених email-ів по групах.
    match /allowed_users/{groupId} {
      allow read: if request.auth != null;
      allow update: if hasAdminRights(groupId) &&
                     request.auth != null &&
                     request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['members']);
      allow create: if false;
      allow delete: if false;
    }

    // Користувач може читати й редагувати тільки свій документ.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /devices/{deviceId} {
        allow read, create, update, delete: if request.auth != null &&
                                             request.auth.uid == userId;
      }
    }

    // Методички по групах.
    match /materials/{groupId}/items/{materialId} {
      allow read: if isInGroup(groupId);
      allow write: if hasEditorRights(groupId);
    }

    // Доступ до групового інструментарію.
    match /tools_by_group/{groupId}/items/{itemId} {
      allow read: if isInGroup(groupId);
      allow create, update, delete: if hasEditorRights(groupId);
    }

    // Заняття по групах.
    match /lessons/{groupId}/items/{lessonId} {
      allow read: if isInGroup(groupId);
      allow create: if hasEditorRights(groupId);
      allow update: if hasEditorRights(groupId) ||
                     isLessonCreator(groupId, lessonId) ||
                     canInstructorManageOwnLessonAssignment(groupId) ||
                     canInstructorUpdateCustomFields(groupId) ||
                     canInstructorAcknowledgeLesson(groupId);
      allow delete: if hasEditorRights(groupId) || isLessonCreator(groupId, lessonId);
    }

    // Відсутності інструкторів по групах.
    match /instructor_absences/{groupId}/items/{absenceId} {
      allow read: if isInGroup(groupId);

      allow create: if isInGroup(groupId) &&
                     request.auth != null &&
                     request.resource.data.instructorId == request.auth.uid &&
                     request.resource.data.creationType == 'user_request' &&
                     request.resource.data.type in ['vacation', 'sick_leave'] &&
                     request.resource.data.status == 'pending';

      allow create: if hasAdminRights(groupId) &&
                     request.auth != null &&
                     request.resource.data.createdBy == request.auth.uid;

      allow update: if isInGroup(groupId) &&
                     request.auth != null &&
                     resource.data.instructorId == request.auth.uid &&
                     resource.data.creationType == 'user_request' &&
                     resource.data.status == 'pending' &&
                     request.resource.data.status == 'cancelled' &&
                     onlyChangedFields(['status', 'modifiedAt']);

      allow update: if hasAdminRights(groupId) &&
                     request.auth != null;

      allow delete: if hasAdminRights(groupId);
    }

    // Групові шаблони й автодоповнення.
    match /groups/{groupId} {
      allow read: if isInGroup(groupId);
      allow write: if hasEditorRights(groupId);

      match /templates/{templateId} {
        allow read: if isInGroup(groupId);
        allow create, update: if hasEditorRights(groupId) &&
                                request.resource.data.groupId == groupId &&
                                request.auth != null;
        allow delete: if hasEditorRights(groupId);
      }

      match /autocomplete_data/{docId} {
        allow read: if isInGroup(groupId);
        allow create, update: if hasEditorRights(groupId) &&
                                docId in ['locations', 'units', 'tags'] &&
                                request.resource.data.keys().hasAll(['items']) &&
                                request.resource.data.items is list;
        allow delete: if hasEditorRights(groupId);
      }

      match /notifications/{notificationId} {
        allow read: if isInGroup(groupId);
        allow create, update: if hasAdminRights(groupId) &&
                                request.auth != null &&
                                request.resource.data.groupId == groupId;
        allow delete: if hasAdminRights(groupId);
      }
    }

    // Файли.
    match /files/{fileId} {
      allow read: if request.auth != null;
    }

    function isInGroup(groupId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowed_users/$(groupId)) &&
        get(/databases/$(database)/documents/allowed_users/$(groupId))
          .data.members[request.auth.token.email] != null;
    }

    function hasEditorRights(groupId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowed_users/$(groupId)) &&
        getUserRole(groupId) in ['editor', 'admin'];
    }

    function hasAdminRights(groupId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowed_users/$(groupId)) &&
        getUserRole(groupId) == 'admin';
    }

    function getUserRole(groupId) {
      let groupDoc = get(/databases/$(database)/documents/allowed_users/$(groupId));
      let memberValue = groupDoc.data.members[request.auth.token.email];

      return memberValue == null ? 'none' :
             (memberValue is string ? memberValue : memberValue.get('role', 'viewer'));
    }

    function isLessonCreator(groupId, lessonId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/lessons/$(groupId)/items/$(lessonId)) &&
        get(/databases/$(database)/documents/lessons/$(groupId)/items/$(lessonId))
          .data.createdBy == request.auth.uid;
    }

    function currentInstructorIdentityCandidates() {
      return request.auth.token.email != null
        ? [request.auth.uid, request.auth.token.email]
        : [request.auth.uid];
    }

    function isAssignedInstructor(lessonData) {
      return request.auth != null &&
        lessonData.instructorIds.hasAny(currentInstructorIdentityCandidates());
    }

    function canInstructorUpdateCustomFields(groupId) {
      return isInGroup(groupId) &&
        isAssignedInstructor(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['customFieldValues', 'updatedAt']);
    }

    function canInstructorAcknowledgeLesson(groupId) {
      let currentAcknowledgements = resource.data.instructorAcknowledgements == null
        ? {}
        : resource.data.instructorAcknowledgements;
      let requestedAcknowledgements = request.resource.data.instructorAcknowledgements == null
        ? {}
        : request.resource.data.instructorAcknowledgements;

      return isInGroup(groupId) &&
        isAssignedInstructor(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['instructorAcknowledgements', 'acknowledgementResetAt', 'updatedAt']) &&
        requestedAcknowledgements
          .diff(currentAcknowledgements)
          .affectedKeys()
          .hasOnly(currentInstructorIdentityCandidates().toSet()) &&
        hasValidOwnAcknowledgement(requestedAcknowledgements);
    }

    function hasValidOwnAcknowledgement(acknowledgements) {
      return (acknowledgements[request.auth.uid] != null &&
              acknowledgements[request.auth.uid].acknowledgedByUid == request.auth.uid) ||
        (request.auth.token.email != null &&
         acknowledgements[request.auth.token.email] != null &&
         acknowledgements[request.auth.token.email].acknowledgedByUid == request.auth.uid);
    }

    function canInstructorManageOwnLessonAssignment(groupId) {
      return isInGroup(groupId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['instructorId', 'instructorName', 'instructorIds', 'instructorNames', 'updatedAt']) &&
        (isSelfTakeLessonUpdate() || isSelfReleaseLessonUpdate());
    }

    function isSelfTakeLessonUpdate() {
      let oldIds = resource.data.instructorIds;
      let newIds = request.resource.data.instructorIds;
      let selfIds = currentInstructorIdentityCandidates();

      return !oldIds.hasAny(selfIds) &&
        newIds.hasAll(oldIds) &&
        newIds.hasAny(selfIds) &&
        newIds.size() == oldIds.size() + 1;
    }

    function isSelfReleaseLessonUpdate() {
      let oldIds = resource.data.instructorIds;
      let newIds = request.resource.data.instructorIds;
      let selfIds = currentInstructorIdentityCandidates();

      return oldIds.hasAny(selfIds) &&
        !newIds.hasAny(selfIds) &&
        oldIds.hasAll(newIds) &&
        newIds.size() + 1 == oldIds.size();
    }

    function onlyChangedFields(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(allowedFields.toSet());
    }
  }
}
